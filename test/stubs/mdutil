#!/usr/bin/env bash
# Стаб mdutil. Логирует вызовы в $VW_STUB_LOG. Состояние индексации задаётся
# через $STUB_SPOTLIGHT (enabled|disabled, по умолчанию enabled).
printf 'mdutil %s\n' "$*" >>"${VW_STUB_LOG:-/dev/null}"
case "${1:-}" in
  -s)
    shift
    printf '%s:\n\tIndexing %s.\n' "${1:-/}" "${STUB_SPOTLIGHT:-enabled}"
    ;;
  -i)
    # -i on|off <path> — просто фиксируем в логе (см. printf выше).
    :
    ;;
esac
exit 0
