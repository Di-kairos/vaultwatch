usage() { t usage; }

# Каталог хуков — тот же, что читает securetrash (общий контракт экосистемы).
ST_HOOK_DIR="${ST_HOOK_DIR:-${HOME}/.securetrash/hooks}"

# Сигнатура managed-хука: по ней отличаем свои хуки от пользовательских.
HOOK_SIGNATURE="# managed-by: vaultwatch"

# Абсолютный путь к этому скрипту (вшиваем в хуки, чтобы не зависеть от PATH).
_self_path() {
  local src="${BASH_SOURCE[0]}"
  local dir
  dir="$(cd -P -- "$(dirname -- "$src")" 2>/dev/null && pwd -P)" || { printf '%s' "$src"; return; }
  printf '%s/%s' "$dir" "$(basename -- "$src")"
}

# Записать один managed-хук, не затирая чужой (без нашей сигнатуры).
_write_hook() {
  local name="$1" action="$2" self="$3"
  local path="${ST_HOOK_DIR}/${name}"
  if [[ -e "$path" ]] && ! grep -qF "$HOOK_SIGNATURE" "$path" 2>/dev/null; then
    warn "$(t hook_skip_foreign "$path")"
    return 0
  fi
  # Экранируем путь до shell-литерала: устойчиво к пробелам/кавычкам/$ в пути.
  local qself; printf -v qself '%q' "$self"
  cat > "$path" <<EOF
#!/usr/bin/env bash
${HOOK_SIGNATURE}
# Вызывается securetrash vault ${name#post-}. \$1 = точка монтирования.
exec ${qself} ${action} "\$@"
EOF
  chmod +x "$path"
}

cmd_install_hooks() {
  # Установка хуков — просто запись файлов, платформо-независима. macOS требуется
  # только ядру start/stop (mdutil/tmutil), где require_macos и стоит (pack 3b).
  mkdir -p "$ST_HOOK_DIR"
  local self; self="$(_self_path)"
  _write_hook post-open  start "$self"
  _write_hook post-close stop  "$self"
  info "$(t hooks_installed "$ST_HOOK_DIR")"
}

cmd_uninstall_hooks() {
  local name path removed=0
  for name in post-open post-close; do
    path="${ST_HOOK_DIR}/${name}"
    [[ -e "$path" ]] || continue
    if grep -qF "$HOOK_SIGNATURE" "$path" 2>/dev/null; then
      rm -f "$path"; removed=1
    else
      warn "$(t hook_skip_rm "$path")"
    fi
  done
  if [[ "$removed" == "1" ]]; then info "$(t hooks_removed "$ST_HOOK_DIR")"; fi
  return 0
}

# --- ядро сторожа (pack 3b): start / stop ----------------------------------

# Каталог состояния сессий. Каждая открытая сессия = один файл (key=value),
# чтобы stop восстановил РОВНО то, что менял start (а не «всё подряд»).
VW_STATE_DIR="${VW_STATE_DIR:-${HOME}/.vaultwatch/sessions}"

# Каталог LaunchAgents для --ttl-таймера (launchd-managed). Переопределяем в тестах.
VW_LAUNCH_DIR="${VW_LAUNCH_DIR:-${HOME}/Library/LaunchAgents}"

# Известные cloud-демоны: "имя_процесса|метка|синк-папка[:ещё-папка]".
# pgrep -x ищет точное имя процесса; папки — для эвристики inside/outside.
# Honest: это эвристика (демоны/папки меняются), не телепатия — так и отчитываемся.
_cloud_table() {
  cat <<EOF
Dropbox|Dropbox|${HOME}/Dropbox
OneDrive|OneDrive|${HOME}/OneDrive:${HOME}/Library/CloudStorage/OneDrive
bird|iCloud Drive|${HOME}/Library/Mobile Documents:${HOME}/Library/CloudStorage/iCloud
Google Drive|Google Drive|${HOME}/Library/CloudStorage/GoogleDrive:${HOME}/Google Drive
EOF
}

# Путь к state-файлу сессии для данной точки монтирования.
# Имя файла — санитизированный mount (collision-устойчивость не критична:
# реально открытых vault единицы, оригинал хранится внутри файла).
_state_file() {
  local mount="$1" safe
  safe="$(printf '%s' "$mount" | tr -c 'a-zA-Z0-9' '_')"
  printf '%s/%s' "$VW_STATE_DIR" "$safe"
}

# child лежит внутри parent? (оба уже канонизированы) — точное совпадение или префикс с '/'.
_is_inside() {
  local child="$1" parent="$2"
  [[ "$child" == "$parent" || "$child" == "$parent/"* ]]
}

# Cloud-детект (только детект): по строке на активный демон в виде "SEV\tТекст",
# SEV = ok|warn (warn = vault ВНУТРИ синк-папки — риск утечки). «Честно про
# эвристику»: смотрим запущенные процессы + расположение папок, не телепатия.
_cloud_lines() {
  local mount="$1" proc label folders f inside cf
  while IFS='|' read -r proc label folders; do
    [[ -n "$proc" ]] || continue
    pgrep -x "$proc" >/dev/null 2>&1 || continue
    inside=0
    IFS=':' read -ra _f <<<"$folders"
    for f in "${_f[@]}"; do
      [[ -n "$f" ]] || continue
      cf="$(_abspath "$f" 2>/dev/null)" || continue
      if _is_inside "$mount" "$cf"; then inside=1; break; fi
    done
    if [[ "$inside" == "1" ]]; then printf 'warn\t%s\n' "$(t cloud_inside "$label")"
    else printf 'ok\t%s\n' "$(t cloud_outside "$label")"; fi
  done < <(_cloud_table)
}

# Презентация cloud-детекта для `start`: ok→info, warn→warn.
_report_cloud_start() {
  local sev text
  while IFS=$'\t' read -r sev text; do
    [[ -n "$text" ]] || continue
    if [[ "$sev" == "warn" ]]; then warn "$text"; else info "$text"; fi
  done < <(_cloud_lines "$1")
}

# Аргумент-точка монтирования: валиден и канонизирован, или выход с ошибкой.
_require_mount() {
  local raw="${1:-}" canon
  if [[ -z "$raw" ]]; then err "$(t need_mount)"; exit 1; fi
  if [[ ! -d "$raw" ]]; then err "$(t mount_missing "$raw")"; exit 1; fi
  canon="$(_abspath "$raw")" || { err "$(t mount_missing "$raw")"; exit 1; }
  printf '%s' "$canon"
}

# Длительность ("30m"/"2h"/"45s"/"1d"/голые секунды) → секунды. !=0 при мусоре.
_parse_duration() {
  local s="${1:-}" n unit
  [[ "$s" =~ ^([0-9]+)([smhd]?)$ ]] || return 1
  n="${BASH_REMATCH[1]}"; unit="${BASH_REMATCH[2]}"
  case "$unit" in
    s|"") printf '%s' "$n" ;;
    m)    printf '%s' "$((n * 60))" ;;
    h)    printf '%s' "$((n * 3600))" ;;
    d)    printf '%s' "$((n * 86400))" ;;
  esac
}

# --- launchd-таймер для --ttl (pack 3d) ------------------------------------
# Одноразовый job: RunAtLoad=true → при загрузке стартует, спит ttl_secs,
# вызывает `_ttl_fire <mount>` и завершается (KeepAlive отсутствует → не
# перезапускается). launchd-managed: виден в `launchctl list`, переживает
# выход родительской оболочки, чисто снимается через bootout.

_ttl_label()      { printf 'com.vaultwatch.ttl.%s' "$(printf '%s' "$1" | tr -c 'a-zA-Z0-9' '_')"; }
_ttl_plist_path() { printf '%s/%s.plist' "$VW_LAUNCH_DIR" "$(_ttl_label "$1")"; }
_ttl_domain()     { printf 'gui/%s' "$(id -u)"; }

# Минимальное XML-экранирование для путей внутри plist.
_xml_escape() {
  local s="$1"
  s="${s//&/&amp;}"; s="${s//</&lt;}"; s="${s//>/&gt;}"; s="${s//\"/&quot;}"
  printf '%s' "$s"
}

# Записать + загрузить LaunchAgent; печатает Label (для записи в state).
_ttl_schedule() {
  local mount="$1" secs="$2" label plist self
  label="$(_ttl_label "$mount")"
  plist="$(_ttl_plist_path "$mount")"
  self="$(_self_path)"
  mkdir -p "$VW_LAUNCH_DIR"
  # ProgramArguments: bash -c с позиционными $1/$2/$3 — спокойно к пробелам в пути.
  cat > "$plist" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>$(_xml_escape "$label")</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>sleep "\$1"; exec "\$2" _ttl_fire "\$3"</string>
    <string>vaultwatch-ttl</string>
    <string>$(_xml_escape "$secs")</string>
    <string>$(_xml_escape "$self")</string>
    <string>$(_xml_escape "$mount")</string>
  </array>
  <key>RunAtLoad</key><true/>
</dict>
</plist>
EOF
  local dom; dom="$(_ttl_domain)"
  launchctl bootout "$dom" "$plist" >/dev/null 2>&1 || true   # снять возможный stale
  if ! launchctl bootstrap "$dom" "$plist" >/dev/null 2>&1; then
    warn "$(t ttl_sched_fail)"
    rm -f "$plist"
    return 0  # не фатально; warn напечатан, stdout пустой → caller получит пустой label
  fi
  printf '%s' "$label"
}

# Снять LaunchAgent (bootout) и удалить plist. Идемпотентно.
_ttl_remove() {
  local mount="$1" plist dom
  plist="$(_ttl_plist_path "$mount")"
  dom="$(_ttl_domain)"
  launchctl bootout "$dom" "$plist" >/dev/null 2>&1 || true
  rm -f "$plist"
}

cmd_start() {
  require_macos
  local ttl_secs=0 ttl_force=0 raw=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ttl)   shift
               ttl_secs="$(_parse_duration "${1:-}")" || { err "$(t ttl_bad "${1:-}")"; exit 1; }
               shift ;;
      --force) ttl_force=1; shift ;;
      --)      shift; raw="${1:-}"; break ;;
      -*)      err "$(t unknown_cmd "$1")"; exit 1 ;;
      *)       raw="$1"; shift ;;
    esac
  done
  local mount; mount="$(_require_mount "$raw")"

  # Spotlight: запоминаем предыдущее состояние, затем выключаем индексацию.
  local spot_was=unknown
  if mdutil -s "$mount" 2>/dev/null | grep -qi "Indexing enabled"; then
    spot_was=enabled
  elif mdutil -s "$mount" 2>/dev/null | grep -qi "Indexing disabled"; then
    spot_was=disabled
  fi
  mdutil -i off "$mount" >/dev/null 2>&1 || true

  # Time Machine: исключаем, только если ещё не исключён (иначе при stop не трогаем).
  local tm_added=0
  if tmutil isexcluded "$mount" 2>/dev/null | grep -qi "\[Included\]"; then
    tmutil addexclusion "$mount" >/dev/null 2>&1 && tm_added=1
  fi

  # Состояние сессии — чтобы stop восстановил ровно изменённое.
  mkdir -p "$VW_STATE_DIR"
  local sf; sf="$(_state_file "$mount")"
  {
    printf 'mount=%s\n' "$mount"
    printf 'started=%s\n' "$(date +%s)"
    printf 'spotlight_was=%s\n' "$spot_was"
    printf 'tm_added=%s\n' "$tm_added"
    printf 'ttl_secs=%s\n' "$ttl_secs"
    printf 'ttl_force=%s\n' "$ttl_force"
  } > "$sf"

  # Авто-выход по таймеру через launchd LaunchAgent. VW_NO_SPAWN=1 подавляет
  # реальную загрузку (юнит-тесты состояния). Label кладём в state — stop снимет.
  if [[ "$ttl_secs" -gt 0 && "${VW_NO_SPAWN:-0}" != "1" ]]; then
    local label; label="$(_ttl_schedule "$mount" "$ttl_secs")"
    printf 'ttl_label=%s\n' "$label" >> "$sf"
  fi

  info "$(t watching "$mount")"
  [[ "$ttl_secs" -gt 0 ]] && info "$(t ttl_scheduled "$(_fmt_duration "$ttl_secs")")"
  _report_cloud_start "$mount"
}

# Секунды → человекочитаемая длительность ("Hh Mm Ss" / "Mm Ss").
_fmt_duration() {
  local s="$1" h m
  h=$((s / 3600)); m=$(((s % 3600) / 60)); s=$((s % 60))
  if (( h > 0 )); then printf '%dh %dm %ds' "$h" "$m" "$s"
  else printf '%dm %ds' "$m" "$s"; fi
}

cmd_stop() {
  require_macos
  local raw="${1:-}"
  if [[ -z "$raw" ]]; then err "$(t need_mount)"; exit 1; fi
  # На close vault уже размонтирован — каталог может не существовать; НЕ требуем -d.
  # ASSUMPTION: путь без симлинков (типично для /Volumes/X) → ключ совпадёт со start.
  local mount; mount="$(_abspath "$raw" 2>/dev/null || printf '%s' "$raw")"
  local sf; sf="$(_state_file "$mount")"
  if [[ ! -f "$sf" ]]; then
    warn "$(t no_session "$mount")"
    return 0
  fi

  # Читаем состояние сессии (parse, не source — shellcheck-clean и безопаснее).
  local started=0 spot_was=unknown tm_added=0 ttl_label="" k v
  while IFS='=' read -r k v; do
    case "$k" in
      started)       started="$v" ;;
      spotlight_was) spot_was="$v" ;;
      tm_added)      tm_added="$v" ;;
      ttl_label)     ttl_label="$v" ;;
    esac
  done < "$sf"

  # Снимаем launchd-таймер авто-выхода (vault закрыт вручную раньше TTL, либо
  # это вызов из самого _ttl_fire — bootout своего же job безопасен).
  [[ -n "$ttl_label" ]] && _ttl_remove "$mount"

  # Восстанавливаем РОВНО то, что меняли. Проверяем результат: если не удалось —
  # сохраняем state file для повторного восстановления после перемонтирования vault.
  local restore_ok=1
  if [[ "$spot_was" == "enabled" ]]; then
    if ! mdutil -i on "$mount" >/dev/null 2>&1; then
      warn "$(t restore_spot_fail "$mount")"
      restore_ok=0
    fi
  fi
  if [[ "$tm_added" == "1" ]]; then
    tmutil removeexclusion "$mount" >/dev/null 2>&1 || true  # работает и без монтирования
  fi

  # --- session report ---
  local now dur; now="$(date +%s)"; dur=$((now - started))
  printf '%s\n' "$(t rep_header)"
  printf '%s\n' "$(t rep_duration "$(_fmt_duration "$dur")")"
  if [[ "$spot_was" == "enabled" ]]; then printf '%s\n' "$(t rep_spot_on "$mount")"
  else printf '%s\n' "$(t rep_spot_keep)"; fi
  if [[ "$tm_added" == "1" ]]; then printf '%s\n' "$(t rep_tm_removed)"
  else printf '%s\n' "$(t rep_tm_keep)"; fi
  local cloud ln; cloud="$(_cloud_lines "$mount" | cut -f2-)"
  if [[ -n "$cloud" ]]; then
    while IFS= read -r ln; do printf '  cloud daemons:   %s\n' "$ln"; done <<<"$cloud"
  else printf '%s\n' "$(t rep_cloud_none)"; fi
  local nsnap; nsnap="$(tmutil listlocalsnapshots / 2>/dev/null | grep -c 'com.apple.TimeMachine' || true)"
  if [[ "${nsnap:-0}" -gt 0 ]]; then printf '%s\n' "$(t rep_snap_some "$nsnap")"
  else printf '%s\n' "$(t rep_snap_none)"; fi
  printf '%s\n' "$(t rep_swap)"

  if [[ "$restore_ok" == "1" ]]; then
    rm -f "$sf"
  else
    warn "$(t restore_incomplete "$mount")"
  fi
}

# Внутренняя команда: срабатывает по истечении --ttl (из фонового таймера).
# Честно про границу: hdiutil detach не размонтирует том с открытыми файлами.
# Заняты файлы → предупреждаем и НЕ трогаем (если только не --force с confirm).
cmd_ttl_fire() {
  require_macos
  local raw="${1:-}"; [[ -n "$raw" ]] || return 0
  local mount; mount="$(_abspath "$raw" 2>/dev/null || printf '%s' "$raw")"
  local sf; sf="$(_state_file "$mount")"
  [[ -f "$sf" ]] || return 0   # сессии нет (закрыт вручную) — тихо

  local ttl_force=0 k v
  while IFS='=' read -r k v; do
    [[ "$k" == "ttl_force" ]] && ttl_force="$v"
  done < "$sf"

  if lsof "$mount" >/dev/null 2>&1; then
    # Том занят открытыми файлами.
    if [[ "$ttl_force" == "1" ]] && confirm "$(t ttl_force_confirm "$mount")"; then
      hdiutil detach -force "$mount" >/dev/null 2>&1 || true
    else
      warn "$(t ttl_busy "$mount")"
      return 0
    fi
  else
    hdiutil detach "$mount" >/dev/null 2>&1 || true
  fi

  # Проверяем, что vault действительно размонтирован (hdiutil || true не гарантирует).
  if [[ -d "$mount" ]]; then
    warn "$(t ttl_detach_fail "$mount")"
    return 1
  fi
  cmd_stop "$mount"
}

cmd_status() {
  require_macos
  local sf mount started spot_was tm_added ttl_secs k v found=0
  if [[ -d "$VW_STATE_DIR" ]]; then
    for sf in "$VW_STATE_DIR"/*; do
      [[ -f "$sf" ]] || continue
      found=1
      mount="" started=0 spot_was=unknown tm_added=0 ttl_secs=0
      while IFS='=' read -r k v; do
        case "$k" in
          mount)         mount="$v" ;;
          started)       started="$v" ;;
          spotlight_was) spot_was="$v" ;;
          tm_added)      tm_added="$v" ;;
          ttl_secs)      ttl_secs="$v" ;;
        esac
      done < "$sf"
      local now elapsed; now="$(date +%s)"; elapsed=$((now - started))
      info "$(t status_session "$mount") (running $(_fmt_duration "$elapsed"))"
      info "$(t status_spot "$spot_was")"
      if [[ "$tm_added" == "1" ]]; then info "$(t status_tm)"; fi
      if [[ "${ttl_secs:-0}" -gt 0 ]]; then
        local remaining=$(( started + ttl_secs - now ))
        if [[ "$remaining" -gt 0 ]]; then info "$(t status_ttl "$(_fmt_duration "$remaining")")"; fi
      fi
    done
  fi
  if [[ "$found" == "0" ]]; then info "$(t status_no_sessions)"; fi
}

cmd_version() { echo "vaultwatch $VERSION"; }

main() {
  local cmd="${1:-}"
  if [[ -z "$cmd" ]]; then usage; exit 1; fi
  shift || true
  case "$cmd" in
    install-hooks)   cmd_install_hooks "$@" ;;
    uninstall-hooks) cmd_uninstall_hooks "$@" ;;
    version|-v|--version) cmd_version "$@" ;;
    help|-h|--help)  usage ;;
    status)          cmd_status "$@" ;;
    start)           cmd_start "$@" ;;
    stop)            cmd_stop "$@" ;;
    _ttl_fire)       cmd_ttl_fire "$@" ;;   # внутренняя: вызывается фоновым TTL-таймером
    *) t unknown_cmd "$cmd" >&2; echo >&2; usage >&2; exit 1 ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
